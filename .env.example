# Copy to .env and set QWEN_BASE_URL / OS_ATLAS_BASE_URL after `make modal-deploy`.

QWEN_BASE_URL=https://REPLACE-ME--qwen-vl--serve.modal.run/v1
QWEN_API_KEY=token-abc123
QWEN_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

OS_ATLAS_BASE_URL=https://REPLACE-ME--os-atlas--serve.modal.run/v1
OS_ATLAS_API_KEY=token-abc123
OS_ATLAS_MODEL=OS-Copilot/OS-Atlas-Base-7B

# live_with_fallback | cache_only | live_only
VLM_CACHE_MODE=cache_only
LOGINGPT_OVERLAY_CLICKS=true

WORKER_REPLICAS=1
BBSA_WORKER_REPLICAS=5
CELERY_CONCURRENCY=1

TARGETS_FILE=targets/targets_mini.txt
FORWARDER_INTERVAL_SECONDS=10

POSTGRES_USER=vv8
POSTGRES_PASSWORD=vv8
POSTGRES_DB=vv8_backend

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=root

JAEGER_ENDPOINT=http://jaeger:14268/api/traces
GRAFANA_ADMIN_PASSWORD=admin
